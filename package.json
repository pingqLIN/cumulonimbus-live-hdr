{
  "name": "cumulonimbus-live-hdr",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Algorithmic cumulonimbus cloud field prototype for live HDR video loops.",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "build:core": "tsc --project tsconfig.json",
    "preview": "vite preview --host 127.0.0.1",
    "render:quick": "npm run build:core && node scripts/render-test-video.mjs --quick",
    "render:test": "npm run build:core && node scripts/render-test-video.mjs",
    "render:demo-loop": "npm run build:core && node scripts/render-demo-loop.mjs",
    "live:url": "node scripts/print-live-url.mjs",
    "capture:3d-still": "npm run build && node scripts/capture-3d-still.mjs",
    "spike:raymarch": "node scripts/raymarch-density-spike.mjs",
    "report:3d-looks": "npm run build && node scripts/report-3d-looks.mjs",
    "tune:demo": "npm run build:core && node scripts/tune-demo-params.mjs",
    "format": "prettier --write .",
    "check": "tsc --noEmit",
    "test": "npm run test:hdr && npm run test:smoke && npm run test:bubble && npm run test:raymarch",
    "test:hdr": "npm run build:core && node scripts/smoke-hdr-calibration.mjs",
    "test:smoke": "npm run build:core && node scripts/smoke-render.mjs",
    "test:bubble": "npm run build:core && node scripts/smoke-bubble-model.mjs",
    "test:raymarch": "node scripts/raymarch-density-spike.mjs --width 90 --height 160 --steps 32 --out outputs/analysis/raymarch-density-smoke.ppm --metrics outputs/analysis/raymarch-density-smoke.json",
    "test:3d-capture": "npm run build && node scripts/smoke-3d-capture.mjs",
    "test:live-entry": "npm run build && node scripts/smoke-live-entry.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/three": "^0.184.1",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "three": "^0.184.0"
  }
}
